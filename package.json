{
  "name": "epic-tag",
  "description": "Advanced styled components for React.",
  "version": "0.0.0-development",
  "repository": "github:tobua/epic-tag",
  "license": "CC-BY-NC-4.0",
  "author": "Matthias Giger",
  "scripts": {
    "check": "biome check --write .",
    "types": "tsc && tsc --project ./test/tsconfig.json"
  },
  "dependencies": {
    "epic-inline": "^0.12.8",
    "logua": "^3.0.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@happy-dom/global-registrator": "^20.9.0",
    "@types/bun": "^1.3.12",
    "@types/jsdom": "^28.0.1",
    "epic-jsx": "^0.12.0",
    "happy-dom": "^20.9.0",
    "typescript": "^6.0.3",
    "zero-configuration": "^1.1.2"
  },
  "trustedDependencies": [
    "zero-configuration"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./index.tsx",
  "exports": {
    ".": "./index.tsx"
  },
  "files": [
    "*.ts",
    "*.tsx"
  ],
  "keywords": [
    "styled",
    "component",
    "tag",
    "jsx",
    "css",
    "inline"
  ],
  "publishConfig": {
    "provenance": true
  },
  "configuration": {
    "gitignore": "bundle",
    "vscode": "biome",
    "biome": {
      "extends": "recommended",
      "linter": {
        "rules": {
          "suspicious": {
            "noExplicitAny": "off"
          },
          "style": {
            "noParameterAssign": "off"
          }
        }
      },
      "files": {
        "includes": [
          "**/*",
          "!demo"
        ]
      }
    },
    "typescript": [
      {
        "extends": "plugin",
        "compilerOptions": {
          "jsx": "react-jsx",
          "types": [
            "bun"
          ],
          "paths": {
            "react": [
              "./node_modules/epic-jsx"
            ],
            "react/jsx-runtime": [
              "./node_modules/epic-jsx"
            ],
            "react/jsx-dev-runtime": [
              "./node_modules/epic-jsx"
            ]
          }
        },
        "files": [
          "index.tsx"
        ]
      },
      {
        "extends": "plugin",
        "folder": "test",
        "compilerOptions": {
          "strict": false,
          "jsx": "react-jsx",
          "types": [
            "bun"
          ],
          "paths": {
            "react": [
              "./../node_modules/epic-jsx"
            ],
            "react/jsx-runtime": [
              "./../node_modules/epic-jsx"
            ],
            "react/jsx-dev-runtime": [
              "./../node_modules/epic-jsx"
            ]
          }
        }
      }
    ]
  }
}
